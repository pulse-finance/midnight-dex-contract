pragma language_version >= 0.22;

import CompactStandardLibrary;
import "./Common";

// Swap fee in basis points (e.g. 10 = 0.1%)
export ledger feeBps: Uint<16>;

// Where the accumulated fees are sent
export ledger treasury: Either<ZswapCoinPublicKey, ContractAddress>;

// only the batcher is allowed to execute these circuits
// the batcher can also change the feeBps and the treasury address
export ledger batcherCommitment: Bytes<32>;
witness batcherSecret(): Bytes<32>;

export ledger xColor: Bytes<32>;
export ledger xLiquidity: Uint<128>;
export ledger xRewards: Uint<128>; // The fee is only charged on the X side

export ledger yColor: Bytes<32>;
export ledger yLiquidity: Uint<128>;

export ledger lpCirculatingSupply: Uint<128>;

/**
 * In the initial phase of Midnight mainnet, the state space of each contract is limited,
 *  so we only allow a single order instead of a collection of many orders.
 */
export ledger slot: Maybe<AmmOrder>;

/**
 * 0: first x liquidity coin (always present)
 * 1: second x liquidity coin (optional)
 * 2: first y liquidity coin (always present)
 * 3: second y liquidity coin (optional)
 */
export ledger coins: Map<Uint<8>, QualifiedShieldedCoinInfo>;

/**
 * The contract constructor only initializes the ledger contract state,
 *  but doesn't yet initialize the liquidity because the contract address isn't available yet.
 */
constructor(
    f: Uint<16>,
    t: Either<ZswapCoinPublicKey, ContractAddress>,
    xc: Bytes<32>, 
    yc: Bytes<32>
) {
    // Fee must be less than 100% (10000 basis points)
    assert(f < 10000, "Fee too high");

    feeBps = disclose(f);
    treasury = disclose(t);
    xColor = disclose(xc);
    yColor = disclose(yc);
}

// useful for using AMM prices as Oracle feeds directly in other contracts
export circuit AmmXLiq(): Uint<128> {
    return xLiquidity;
}

// useful for using AMM prices as Oracle feeds directly in other contracts
export circuit AmmYLiq(): Uint<128> {
    return yLiquidity;
}

/**
 * Receives xIn and yIn, and then mints lpOut sending it to the recipient.
 * This can technically only be done by batcher, but pools not initialized by us will be ignored anyway
 */
export circuit AmmInitXYLiq(
    xIn: Uint<64>,
    yIn: Uint<64>,
    lpOut: Uint<64>,
    recipient: Either<ZswapCoinPublicKey, ContractAddress>,
    nonce: Bytes<32>
): [] {
    assert(lpCirculatingSupply == 0, "Already initialized");
    assert(lpOut*lpOut <= xIn*yIn, "Too many LP tokens taken");

    batcherCommitment = disclose(generateBatcherCommitment());

    // mint and send lp tokens to recipient (shielded)
    lpCirculatingSupply = disclose(lpOut);
    mintShieldedToken(
        getLPTokenName(),
        disclose(lpOut),
        disclose(nonce),
        disclose(recipient)
    );

    const contractAddress = getShieldedContractAddress();

    // send the x liquidity to the contract (shielded)
    xLiquidity = disclose(xIn);
    const xCoin = ShieldedCoinInfo{
        disclose(nonce),
        xColor,
        xLiquidity
    };
    receiveShielded(xCoin);
    coins.insertCoin(0, xCoin, contractAddress);

    // send the y liquidity to the contract (shielded)
    yLiquidity = disclose(yIn);
    const yCoin = ShieldedCoinInfo{
        disclose(nonce),
        yColor,
        yLiquidity
    };
    receiveShielded(yCoin);
    coins.insertCoin(2, yCoin, contractAddress);
}

/**
 * Starts the liquidity provision process using X+Y
 */
export circuit AmmDepositXYLiq(
    xIn: Uint<64>,
    yIn: Uint<64>,
    returnsTo: CircuitId,
    nonce: Bytes<32>
): [] {
    assertOnlyBatcher();
    assert(lpCirculatingSupply > 0, "Not yet initialized");
    assert(!slot.is_some, "Another order is pending");

    const contractAddress = getShieldedContractAddress();

    const inputXCoin = ShieldedCoinInfo{
        disclose(nonce),
        xColor,
        disclose(xIn)
    };

    receiveShielded(inputXCoin);

    assert(!coins.member(1), "Coin position 1 already occupied");

    coins.insertCoin(1, inputXCoin, contractAddress);

    const inputYCoin = ShieldedCoinInfo{
        disclose(nonce),
        yColor,
        disclose(yIn)
    };

    receiveShielded(inputYCoin);

    assert(!coins.member(3), "Coin position 3 already occupied");

    coins.insertCoin(3, inputYCoin, contractAddress);

    slot = some<AmmOrder>(AmmOrder{
        AmmOrderKind.ValidateDepositXYLiq,
        disclose(xIn),
        disclose(yIn),
        disclose(returnsTo)
    });
}

/**
 * Starts the liquidity provision process using X zap-in
 */
export circuit AmmDepositXLiq(
    xIn: Uint<64>,
    returnsTo: CircuitId,
    nonce: Bytes<32>
): [] {
    assertOnlyBatcher();
    assert(lpCirculatingSupply > 0, "Not yet initialized");
    assert(!slot.is_some, "Another order is pending");

    const inputXCoin = ShieldedCoinInfo{
        disclose(nonce),
        xColor,
        disclose(xIn)
    };

    receiveShielded(inputXCoin);

    const contractAddress = getShieldedContractAddress();

    assert(!coins.member(1), "Coin position 1 already occupied");
    coins.insertCoin(1, inputXCoin, contractAddress);

    slot = some<AmmOrder>(AmmOrder{
        AmmOrderKind.ValidateDepositXLiq,
        disclose(xIn),
        0,
        disclose(returnsTo)
    });
}

