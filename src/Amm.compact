/**
 * Starts the liquidity withdrawal process to receive X+Y
 */
export circuit AmmWithdrawXYLiq(
    lpIn: Uint<64>,
    returnsTo: CircuitId,
    nonce: Bytes<32>
): [] {
    assertOnlyBatcher();
    assert(!slot.is_some, "Amm slot not empty");

    const coin = ShieldedCoinInfo{
        disclose(nonce),
        getLPTokenColor(),
        disclose(lpIn)
    };

    // receiveShielded acts as burn here, no other circuit allows spending this shielded coin
    receiveShielded(coin);

    slot = some<AmmOrder>(AmmOrder{
        AmmOrderKind.ValidateWithdrawXYLiq,
        disclose(lpIn),
        0,
        disclose(returnsTo)
    });
}

