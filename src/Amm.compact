    assert(!slot.is_some, "Amm slot not empty");

    const coin = ShieldedCoinInfo{
        disclose(nonce),
        getLPTokenColor(),
        disclose(lpIn)
    };

    // receiveShielded acts as burn here, no other circuit allows spending this shielded coin
    receiveShielded(coin);

    slot = some<AmmOrder>(AmmOrder{
        AmmOrderKind.ValidateWithdrawXLiq,
        disclose(lpIn),
        0,
        disclose(returnsTo)
    });
}

/** 
 * Starts the liquidity withdrawal process to receive Y
 */
export circuit AmmWithdrawYLiq(
    lpIn: Uint<64>,
    returnsTo: CircuitId,
    nonce: Bytes<32>
): [] {
    assertOnlyBatcher();
    assert(!slot.is_some, "Amm slot not empty");

    const inputLPCoin = ShieldedCoinInfo{
        disclose(nonce),
        getLPTokenColor(),
        disclose(lpIn)
    };

    // receiveShielded acts as burn here, no other circuit allows spending this shielded coin
    receiveShielded(inputLPCoin);

    slot = some<AmmOrder>(AmmOrder{
        AmmOrderKind.ValidateWithdrawYLiq,
        disclose(lpIn),
