{
  "name": "@pulsefinance/dex-contract",
  "version": "0.5.0",
  "description": "Compact contracts for Pulse's Midnight DEX",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./amm": "./dist/amm/contract/index.js",
    "./faucet": "./dist/faucet/contract/index.js",
    "./marketorder": "./dist/marketorder/contract/index.js",
    "./mintlporder": "./dist/mintlporder/contract/index.js",
    "./burnlporder": "./dist/burnlporder/contract/index.js"
  },
  "scripts": {
    "prepare": "node ./scripts/build.mjs",
    "build": "node ./scripts/build.mjs",
    "build:amm": "node ./scripts/build.mjs amm",
    "build:faucet": "node ./scripts/build.mjs faucet",
    "build:marketorder": "node ./scripts/build.mjs marketorder",
    "build:mintlporder": "node ./scripts/build.mjs mintlporder",
    "build:burnlporder": "node ./scripts/build.mjs burnlporder",
    "docker:up": "docker compose -f ./compose.yml up -d",
    "prettify": "prettier --write \"**/*.ts\"",
    "test:integ": "bun ./test/integ/index.ts",
    "test:types": "tsc --noEmit",
    "test:unit": "bun test ./test/unit/"
  },
  "keywords": [],
  "author": "Christian Schmitz",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "tabWidth": 2,
    "semi": false,
    "printWidth": 100
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0"
  },
  "pnpm": {
    "overrides": {
      "@midnight-ntwrk/ledger-v8": "8.0.3"
    },
    "patchedDependencies": {
      "@midnight-ntwrk/midnight-js-contracts": "patches/@midnight-ntwrk__midnight-js-contracts.patch",
      "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "patches/@midnight-ntwrk__midnight-js-indexer-public-data-provider.patch",
      "@midnight-ntwrk/wallet-sdk-dust-wallet@3.0.0": "patches/@midnight-ntwrk__wallet-sdk-dust-wallet@3.0.0.patch"
    }
  }
}
